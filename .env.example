# NextAuth（ログイン時に Cookie が発行され、/api/slack-manual-report などで管理者判定に使われます）
# Vercel 本番では NEXTAUTH_URL=https://あなたのドメイン.vercel.app も必須
# AUTH_SECRET と NEXTAUTH_SECRET のどちらか一方を設定（未設定だと 503）
# 例: openssl rand -base64 32
AUTH_SECRET=your-long-random-secret
# NEXTAUTH_URL=http://localhost:3000

# Supabase（業務進捗・活動報告アプリのデータ保存先）
# https://supabase.com のプロジェクト設定から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Slack Incoming Webhooks（通知先チャンネルは Webhook 作成時に決まる）
# SLACK_WEBHOOK_URL は必須推奨: デイリー・レポート・ROI・催促・週次CSV など「すべて」のデフォルト送信先になる。
# 用途別 URL を空のまま置いたり省略した場合でも、必ずこの SLACK_WEBHOOK_URL が使われる。
# 一部だけ別チャンネルにしたいときだけ、下記の個別変数に URL を入れる（有効な文字列のときのみ上書き）。
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxx/xxxx/xxxx
# SLACK_WEBHOOK_DAILY_URL=...        # 毎日の「本日の稼働予定者」（/api/slack-daily・JST 朝 8:00 前後想定）。土曜・日曜（JSTの対象日）は送信しない
# SLACK_WEBHOOK_REPORT_URL=...       # 日次 KPI レポート（/api/slack-report）
# SLACK_WEBHOOK_RANKING_URL=...      # 定期 ROI ランキング（/api/slack-ranking）※ vercel.json から Cron 停止済み
# SLACK_WEBHOOK_MANUAL_REPORT_URL=... # 管理画面からの期間指定 ROI（server action）※管理画面の送信ボタン廃止済み
# SLACK_WEBHOOK_REMIND_URL=...       # シフト未入力催促（/api/cron/remind-unsubmitted）※ vercel.json から Cron 停止済み
# SLACK_WEBHOOK_WEEKLY_SCHEDULE_URL=... # 週次稼働予定 CSV（/api/cron/weekly-schedule-report）※ vercel.json から Cron 停止済み
# SLACK_WEBHOOK_PRODUCTIVITY_URL=...   # KPI 保存直後の即時アラート（有効コール / 稼働時間が 10件/h 未満。未設定時は SLACK_WEBHOOK_URL）
# SLACK_PRODUCTIVITY_NOTIFY_USER_IDS=Uxxx,Uyyy  # 省略時はコード内の既定メンバーへ <@…> メンション
# SLACK_WEBHOOK_MISSED_PUNCH_URL=...    # 未打刻アラート（開始・終了）（/api/cron/missed-punch-start・既定は 5 分ごと UTC）。未設定時は SLACK_WEBHOOK_URL
# SLACK_WEBHOOK_KPI_MISSING_URL=...   # 終了打刻後も KPI 未入力のアラート（本日 JST の終了打刻＋猶予後、クライアントから 1 回試行）。未設定時は SLACK_WEBHOOK_URL
# SLACK_KPI_MISSING_AT_HERE=1         # 上記アラートの先頭メンションを <!here> のみにする（未設定時は単一 U…）
# SLACK_KPI_MISSING_NOTIFY_USER_ID=Uxxxxxxxx  # 上記アラートでメンションする Slack ユーザー ID（1 名のみ）
# MISSED_PUNCH_START_GRACE_MINUTES=15  # 予定開始・予定終了から何分経過後に未打刻とみなすか（0〜240、省略時 15）※開始・終了の両方に適用
# KPI_MISSING_AFTER_PUNCH_MINUTES=15   # 終了打刻（本日 JST 0:00 以降の end_raw の最大）から何分後に KPI 未入力を通知するか（0〜240、省略時 15）

# 毎日の稼働予定 Slack（/api/slack-daily）は Vercel Cron で UTC 23:00（日本時間 朝 8:00）に実行される想定（vercel.json）
# 未打刻アラートは vercel.json で UTC 5 分ごとに /api/cron/missed-punch-start を実行（開始・終了の両方をチェック）
# KPI 未入力（終了打刻＋猶予後）は Cron では送らず、アプリ内タイマーと KPI タブ表示で判定します（/api/cron/kpi-missing-after-punch は無効）

# /api/slack-daily（Cron・手動POST）の認証に必須。Vercel プロジェクトの Environment Variables にも同じ値を設定し、Cron が付与する Bearer と一致させる
CRON_SECRET=your-long-random-secret

# Googleフォーム連携 Webhook（/api/webhooks/google-form-register）の Bearer 認証
# 未設定時は認証スキップ（ローカル検証用）。本番では必ず設定し GAS 側も同値を Authorization に付与
EXTERNAL_REGISTER_SECRET=your-long-random-secret

# 請求書一括記帳（GAS Webhook）
# INVOICE_GAS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
# INVOICE_GAS_TOKEN=your-invoice-gas-token

# 請求書 PDF の Google Drive 直アップロード（GAS で base64 を保存せず PDF バイナリを直接保存・文字化け回避に推奨）
# サービスアカウントに Drive の親フォルダを「編集者」で共有すること
# INVOICE_DRIVE_ROOT_FOLDER_ID=your-drive-folder-id
# INVOICE_DRIVE_SERVICE_ACCOUNT_EMAIL=...@....iam.gserviceaccount.com
# INVOICE_DRIVE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# シフト催促（/api/cron/remind-unsubmitted・金土20:00 JST）でメンションするには、
# Supabase の users テーブルに slack_id 列（text）を追加し、管理画面で各メンバーの Slack ユーザーID（U…）を保存する。
# 例: ALTER TABLE users ADD COLUMN IF NOT EXISTS slack_id text;
